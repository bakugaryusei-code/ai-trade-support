# ─────────────────────────────────────────
# secrets.toml のひな型（テンプレート）
#
# 使い方：
#   1. このファイルをコピーして `secrets.toml` という名前で
#      同じフォルダ（.streamlit/）に保存する
#   2. 下の "YOUR_..._HERE" の部分に自分の実キーを貼り付ける
#   3. secrets.toml は .gitignore に含まれているので
#      GitHubにはアップロードされない（重要）
#
# 本番デプロイ時（Streamlit Community Cloud）：
#   → Streamlit Cloud の「Secrets」設定画面に同じ内容を貼り付ける
# ─────────────────────────────────────────

# J-Quants API V2（株価データ取得）
# 取得先: https://jpx-jquants.com/ のダッシュボード → 「API Keys」で発行
# x-api-key ヘッダーで使用される。有効期限なし（再発行・削除は可能）
JQUANTS_API_KEY = "YOUR_JQUANTS_API_KEY_HERE"

# Claude API（分析・推奨生成）
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY = "YOUR_ANTHROPIC_API_KEY_HERE"
